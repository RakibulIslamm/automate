# ─────────────────────────────────────────────────────────────
# AutoMate — environment variables
# Copy to .env.local and fill in. Vars marked REQUIRED are
# validated at boot (src/lib/env.ts).
# ─────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────
# REQUIRED
MONGODB_URI=

# ── Auth (Auth.js v5 — next-auth@beta) ───────────────────────
# REQUIRED — generate with: openssl rand -base64 32
AUTH_SECRET=
# REQUIRED
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# REQUIRED — Resend API key used for magic-link delivery
AUTH_RESEND_KEY=
# REQUIRED — must be a valid email address
RESEND_FROM_EMAIL=

# Optional — Auth.js infers these in most cases
AUTH_URL=
AUTH_TRUST_HOST=

# ── AI (OpenRouter → Claude) ─────────────────────────────────
# REQUIRED
OPENROUTER_API_KEY=
# REQUIRED — e.g. https://openrouter.ai/api/v1
OPENROUTER_BASE_URL=
# Optional override; defaults to anthropic/claude-sonnet-4.6
OPENROUTER_MODEL=

# ── Queue / scheduling (Upstash QStash) ──────────────────────
# REQUIRED
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# ── Stripe (metered billing) ─────────────────────────────────
# REQUIRED
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Price IDs land in Phase 11

# ── Security ─────────────────────────────────────────────────
# REQUIRED — 64 hex chars (32 bytes). Generate: openssl rand -hex 32
ENCRYPTION_KEY=
# REQUIRED — min 16 chars. Signs queue payloads.
WORKFLOW_SIGNING_SECRET=

# ── Integration OAuth (Arctic — separate apps from Auth.js sign-in) ───────
# REQUIRED — Google Cloud OAuth client for Gmail/Drive/Calendar scopes.
# Add ${NEXT_PUBLIC_APP_URL}/api/oauth/google/callback to authorized redirect URIs.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
# Optional HTTPS callback URL override. Slack refuses bot scopes on non-HTTPS
# redirect URIs (http://localhost included), so local dev needs a tunnel.
# Example: SLACK_REDIRECT_URI=https://abc123.ngrok.app/api/oauth/slack/callback
SLACK_REDIRECT_URI=
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=

# ── Public (exposed to the browser) ──────────────────────────
# REQUIRED — e.g. http://localhost:3000 in dev
NEXT_PUBLIC_APP_URL=
# REQUIRED — Stripe publishable key (pk_test_… in dev)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
