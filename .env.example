# ─────────────────────────────────────────────────────────────
# AutoMate — environment variables
# Copy to .env.local and fill in per phase.
# ─────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────
MONGODB_URI=
MONGODB_DB_NAME=

# ── Auth (Auth.js v5) ────────────────────────────────────────
AUTH_SECRET=
AUTH_URL=
AUTH_TRUST_HOST=

# ── OAuth: sign-in providers ─────────────────────────────────
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_RESEND_KEY=
AUTH_EMAIL_FROM=

# ── OAuth: connected integrations (Arctic) ───────────────────
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
GOOGLE_INTEGRATION_CLIENT_ID=
GOOGLE_INTEGRATION_CLIENT_SECRET=

# ── AI (OpenRouter → Claude) ─────────────────────────────────
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4.6

# ── Queue / Scheduling (Upstash QStash) ──────────────────────
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=
QSTASH_URL=

# ── Email (Resend) ───────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# ── Stripe (metered billing) ─────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_METERED=
STRIPE_PORTAL_RETURN_URL=

# ── Security ─────────────────────────────────────────────────
ENCRYPTION_KEY=
INTERNAL_API_TOKEN=

# ── Public (exposed to the browser) ──────────────────────────
NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_APP_NAME=AutoMate
